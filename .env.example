# Copy to .env and fill in (never commit .env)
# Used by: mqtt_probe.py, discover_devices.py, power_flow.py, mqtt_debug.py, test_login.py

# EcoFlow app credentials (same as mobile app)
ECOFLOW_EMAIL=
ECOFLOW_PASSWORD=

# Ocean Pro defaults — update serial if different
ECOFLOW_SERIAL=HR51ZA1AVH770253
ECOFLOW_PRODUCT_TYPE=88
ECOFLOW_REGION=us

# Home Assistant (Forest Home) — optional, for ha_probe.py / power_flow.py --ha
HA_URL=http://172.16.255.250:8123
HA_TOKEN=
