# Copy to web/.env (never commit secrets)

# Multi-home layout: Forest + Desert (CDO)
SITES=forest,desert

# Shared EcoFlow account fallback (used when a site omits its own email/password)
ECOFLOW_EMAIL=
ECOFLOW_PASSWORD=
ECOFLOW_REGION=us

# --- Forest Home (leave SERIALS empty until that system is installed) ---
SITE_FOREST_LABEL=Forest Home
# Optional override if Forest uses a different EcoFlow login:
# SITE_FOREST_EMAIL=
# SITE_FOREST_PASSWORD=
SITE_FOREST_REGION=us
# Comma-separated inverter/panel/EV serials for Forest (add when online)
SITE_FOREST_SERIALS=

# --- Desert House (CDO Ocean) ---
SITE_DESERT_LABEL=Desert House (CDO)
SITE_DESERT_REGION=us
SITE_DESERT_SERIALS=HR51ZA1AVH770253,HR61ZA1AVH7X0100,C102ZA1AZH6G0018

# Optional LAN auth — open http://host:8080/?token=...
WEB_AUTH_TOKEN=

# Sampling / retention
SAMPLE_INTERVAL_S=30
REST_POLL_INTERVAL_S=60
HISTORY_RETENTION_DAYS=90
DATA_DIR=/data
LOG_LEVEL=INFO
